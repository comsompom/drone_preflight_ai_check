# Copy this file to .env and fill in your values.
# Do not commit .env (it is in .gitignore).

# Your agent endpoint URL (from DigitalOcean agent Overview / Settings).
# Example: https://xxxxxxxx.agents.do-ai.run
AGENT_URL=https://your-agent-id.agents.do-ai.run

# Your agent endpoint access key (from Settings > Endpoint Access Keys).
# Create a key in the control panel and paste the secret here.
AGENT_API_KEY=your_secret_key_here
